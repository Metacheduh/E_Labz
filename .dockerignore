# Exclude everything not needed by the scheduler
.git
.gitignore
.github
.agents
.gemini
node_modules
__pycache__
*.pyc

# Large dirs not needed in container
products/
archive/
portfolio/
ADK_Pipelines/
tests/
docs/

# Media and artifacts
*.png
*.jpg
*.webp
*.mp4
*.zip

# Dev files
*.md
LICENSE
.env.example
