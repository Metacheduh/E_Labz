# AutoStack ADK — Environment Template
# Copy this to .env and fill in your values
# NEVER commit .env to git

# Required: Google Gemini API
GOOGLE_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Optional: Add as pipelines need them
# SERPAPI_KEY=your_key_here          # for Google search (leadgen, intelscout)
# FORMSPREE_KEY=your_key_here       # for email capture
# APIFY_TOKEN=your_token_here       # for advanced web scraping
# AYRSHARE_KEY=your_key_here        # for social media posting
# GUMROAD_TOKEN=your_token_here     # for product publishing
